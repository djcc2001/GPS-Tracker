[Unit]
Description=GPS Tracker API
After=network.target postgresql.service

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/gps_server
Environment="PATH=/home/ubuntu/gps_server/venv/bin"
ExecStart=/home/ubuntu/gps_server/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always

[Install]
WantedBy=multi-user.target
